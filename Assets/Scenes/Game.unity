--- !u!114 &1782154766
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1782154762}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7c7d86a22cd40d51d9a680b2ba878227, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textDisplay: {fileID: 378412144}
  sentences:
  - 'Dr. Cornelius: My! Thank goodness you''re here! I am in need of assistance and
    you seem like the right cat for the job.'
  - 'Dr. Cornelius: I was experimenting with the sentient properties of Gunk when
    it got out of hand and started to multiply.'
  - 'Dr. Cornelius: Please! Help me to exterminate these nasty GunkBalls. And whatever
    you do ... don''t let them touch you.'
  - 'Dr. Cornelius: Use the Cannon on your back to defend yourself. Aim with the
    Cursor and hold down Right Click to shoot. '
  - 'Dr. Cornelius: Come back to me when you''ve defeated all of the GunkBalls. Best
    of Luck!'
